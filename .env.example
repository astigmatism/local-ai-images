# Local AI Images container defaults

HOST=0.0.0.0
PORT=8000
NODE_ENV=production
LOG_LEVEL=info

# Image backend
IMAGE_GENERATION_ENABLED=true
IMAGE_BACKEND=comfyui

# When ComfyUI runs as another Compose service, use:
COMFYUI_BASE_URL=http://comfyui:8188

# If ComfyUI remains installed directly on the Docker host instead,
# Compose will need host-gateway wiring and this should become:
# COMFYUI_BASE_URL=http://host.docker.internal:8188

# Runtime state inside the container
CONFIG_PATH=/app/config/local-ai-images.json
IMAGE_WORKFLOW_PATH=/app/config/workflows
IMAGE_ARTIFACT_PATH=/app/data/artifacts
IMAGE_ARTIFACT_PUBLIC_BASE_URL=/api/v1/artifacts

# Shared model root mounted by Docker Compose.
# On the target machine this should map to /home/astigmatism/ai/models.
IMAGE_MODEL_PATHS=/models

# ComfyUI-compatible model category paths inside the container.
# These must point into the same mounted shared model root.
COMFYUI_CHECKPOINT_PATH=/models/checkpoints
COMFYUI_LORA_PATH=/models/loras
COMFYUI_VAE_PATH=/models/vae
COMFYUI_CONTROLNET_PATH=/models/controlnet
COMFYUI_UPSCALER_PATH=/models/upscale_models
COMFYUI_OTHER_MODEL_PATH=/models

# Workflow/default model behavior
IMAGE_DEFAULT_WORKFLOW_ID=sdxl-text-to-image
IMAGE_DEFAULT_MODEL=
IMAGE_PRELOAD_DEFAULT_ON_STARTUP=false
IMAGE_PRELOAD_TIMEOUT_MS=120000
IMAGE_PRELOAD_WORKFLOW_ID=sdxl-text-to-image
IMAGE_PRELOAD_WIDTH=512
IMAGE_PRELOAD_HEIGHT=512
IMAGE_PRELOAD_STEPS=1
IMAGE_PRELOAD_KEEP_ARTIFACT=false
IMAGE_QUEUE_CONCURRENCY=1
IMAGE_MAX_QUEUED_JOBS=32

# API security
IMAGE_API_KEYS=replace-with-a-long-random-secret
REQUIRE_IMAGE_API_AUTH=true

# Optional model install/download controls
MODEL_INSTALLS_ENABLED=false
MODEL_INSTALL_MAX_BYTES=21474836480
MODEL_INSTALL_ALLOW_CKPT=false
MODEL_CATALOG_PATH=/app/config/model-catalog.json
MODEL_DOWNLOAD_METADATA_PATH=/app/config/model-downloads.json

# Legacy Ollama compatibility stays off for normal ComfyUI image deployment
LEGACY_OLLAMA_ENABLED=false
OLLAMA_BASE_URL=