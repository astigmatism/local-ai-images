[Unit]
Description=Local AI control panel and ComfyUI image API
After=network-online.target comfyui.service ollama.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/local-ai-llm
EnvironmentFile=-/opt/local-ai-llm/.env
ExecStart=/usr/bin/npm start
Restart=on-failure
RestartSec=5
User=local-ai-llm
Group=local-ai-llm
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/opt/local-ai-llm/config /opt/local-ai-llm/data /var/lib/local-ai-image

[Install]
WantedBy=multi-user.target
